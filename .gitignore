# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ansible
.ansible/
*.retry

# Kubernetes / Helm
.kube/
charts/*.tgz

# SOPS / age — never commit private keys, regardless of location
keys.txt
**/keys.txt
*.agekey
*.age-key

# Local secrets-in-progress (encrypt or delete; do not commit plaintext)
*.dec
*.decrypted

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo

# Python (pre-commit creates venvs but stores them under ~/.cache)
__pycache__/
*.pyc

# Terraform local state
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfvars      # contains your SSH key + non-secret VM map; ok to commit if you prefer

# SOPS plaintext should never appear; encrypted *.enc.yaml IS committed.
**/secrets.auto.tfvars

# Application source code (out-of-repo by design).
#
# This infrastructure repo is public (ADR-0008). Application source trees
# pulled in for local reference during a migration must NOT be committed:
# they have their own repos, their own ownership, and their own visibility
# rules that this repo's posture cannot speak for.
#
# Convention: clone or copy app source under "Apps Code/<App Name>/<repo>/"
# at the repo root. The whole "Apps Code/" tree is gitignored. Examples:
#   Apps Code/Resume App Updated/my-resume-app-code/
#   Apps Code/<future-app>/<future-repo>/
#
# If app source has already been "git add"-ed in error, untrack with
#   git rm -r --cached "Apps Code/"
# (no working-tree deletion) before the next commit.
/Apps Code/